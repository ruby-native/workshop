<% content_for :title, "Your profile" %>

<%= native_form_tag %>
<%= native_navbar_tag("Your profile") do |navbar| %>
  <% navbar.submit_button title: "Save", click: "#profile-submit" %>
<% end %>

<header class="native:hidden mb-[18px] flex items-center gap-1.5">
  <%= link_to "‹ Settings", settings_path, class: "px-0.5 py-1 text-[15px] font-semibold text-muted" %>
  <h1 class="text-xl font-bold tracking-tight">Your profile</h1>
</header>

<div class="rounded-2xl border border-line bg-surface p-4 shadow-card">
  <%= form_with model: @user, url: profile_path, method: :patch do |form| %>
    <% if @user.errors.any? %>
      <div class="form-errors"><%= @user.errors.full_messages.to_sentence.capitalize %>.</div>
    <% end %>

    <div class="mb-[15px]">
      <%= form.label :name, class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.text_field :name, autocomplete: "name" %>
    </div>

    <div class="mb-[15px]">
      <%= form.label :email_address, "Email", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.email_field :email_address, autocomplete: "username" %>
    </div>

    <hr class="my-[18px] border-0 border-t border-line">

    <div class="mb-[15px]">
      <%= form.label :password, "New password", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.password_field :password, autocomplete: "new-password", placeholder: "Leave blank to keep current",
            minlength: 6, maxlength: 72 %>
    </div>

    <%= form.submit "Save", id: "profile-submit", class: "btn btn-primary btn-block native:hidden" %>
  <% end %>
</div>
