<% content_for :title, "Home" %>

<%= native_navbar_tag("Penny Pincher") %>
<%= native_fab_tag(icon: "plus", href: new_expense_path) %>

<header class="native:hidden mb-[18px]">
  <h1 class="text-[26px] font-bold tracking-tight">Where you stand</h1>
</header>

<%= link_to new_expense_path, class: "native:hidden fixed bottom-[calc(22px+env(safe-area-inset-bottom))] right-[calc(18px+env(safe-area-inset-right))] z-30 inline-flex items-center gap-2 rounded-full bg-brand px-5 py-3.5 font-bold text-white shadow-[0_8px_24px_rgb(22_163_74_/_0.4)]" do %>
  <span class="text-xl leading-none">+</span> Add expense
<% end %>

<% if @summary.any_categories? %>
  <section class="mt-[22px]">
    <%= render "summary_card", title: "#{@summary.month_label} snapshot",
          spent: @summary.snapshot_spent, budget: @summary.snapshot_budget,
          remaining: @summary.snapshot_remaining, percent: @summary.snapshot_percent %>
  </section>

  <% if @summary.weekly.any? %>
    <section class="mt-[22px]">
      <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Weekly budgets</h2>
      <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
        <%= render partial: "category_progress", collection: @summary.weekly, as: :progress %>
      </div>
    </section>
  <% end %>

  <% if @summary.monthly.any? %>
    <section class="mt-[22px]">
      <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Monthly budgets</h2>
      <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
        <%= render partial: "category_progress", collection: @summary.monthly, as: :progress %>
      </div>
    </section>
  <% end %>
<% else %>
  <section class="rounded-2xl border border-line bg-surface px-4 py-[26px] text-center shadow-card">
    <p class="font-bold">No categories yet</p>
    <p class="mt-1.5 mb-3.5 text-sm text-muted">Add a category with a weekly or monthly budget to start tracking.</p>
    <%= link_to "Add a category", new_category_path, class: "btn btn-primary" %>
  </section>
<% end %>

<section class="mt-[22px]">
  <div class="flex items-baseline justify-between">
    <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Recent</h2>
    <% unless @logged_today %>
      <span class="rounded-full bg-warn/15 px-2.5 py-0.5 text-xs font-semibold text-warn">Nothing logged today</span>
    <% end %>
  </div>

  <% if @recent_expenses.any? %>
    <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
      <%= render @recent_expenses %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-line bg-surface px-4 py-[26px] text-center shadow-card">
      <p class="font-bold">No expenses yet</p>
      <p class="mt-1.5 text-sm text-muted">Tap the + button to log your first one.</p>
    </div>
  <% end %>
</section>
