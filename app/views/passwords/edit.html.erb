<% content_for :title, "Update password" %>

<%= native_navbar_tag("Update password") %>

<div class="mx-auto w-[min(100%-2rem,400px)] pt-10">
  <div class="mb-[22px] text-center">
    <span class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-brand text-[34px] font-extrabold text-white">¢</span>
    <h1 class="mt-3.5 text-2xl">Update your password</h1>
  </div>

  <%= form_with url: password_path(params[:token]), method: :put, class: "rounded-2xl border border-line bg-surface p-4 shadow-card" do |form| %>
    <div class="mb-[15px]">
      <%= form.label :password, "New password", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.password_field :password, required: true, autofocus: true, autocomplete: "new-password",
            placeholder: "New password", minlength: 6, maxlength: 72 %>
    </div>
    <div class="mb-[15px]">
      <%= form.label :password_confirmation, "Confirm password", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
            placeholder: "Repeat new password", maxlength: 72 %>
    </div>
    <%= form.submit "Save password", class: "btn btn-primary btn-block" %>
  <% end %>
</div>
