<%= form_with model: @category do |form| %>
  <% if @category.errors.any? %>
    <div class="form-errors">
      <%= @category.errors.full_messages.to_sentence.capitalize %>.
    </div>
  <% end %>

  <div class="flex gap-3">
    <div class="mb-[15px] w-[84px]">
      <%= form.label :emoji, "Icon", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.text_field :emoji, maxlength: 4, class: "emoji-input", placeholder: "🛒",
            autocomplete: "off", aria: { label: "Emoji icon" } %>
    </div>
    <div class="mb-[15px] flex-1">
      <%= form.label :name, class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.text_field :name, placeholder: "Groceries", autofocus: @category.new_record? %>
    </div>
  </div>

  <div class="mb-[15px]">
    <span class="mb-1.5 block text-sm font-semibold">Color</span>
    <div class="swatches">
      <% Category::COLORS.each do |color| %>
        <label class="swatch" style="--swatch: <%= color %>">
          <%= form.radio_button :color, color, checked: @category.color == color, class: "swatch-input" %>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-[15px]">
    <%= form.label :budget_amount, "Budget", class: "mb-1.5 block text-sm font-semibold" %>
    <div class="amount-inline">
      <span class="amount-currency-sm">$</span>
      <%= form.number_field :budget_amount, min: 0, step: 1, inputmode: "numeric", placeholder: "0" %>
    </div>
    <p class="mt-1.5 text-[13px] text-muted">Whole dollars, no cents.</p>
  </div>

  <fieldset class="picker">
    <legend>Resets every</legend>
    <div class="segmented">
      <label class="seg">
        <%= form.radio_button :period, "weekly", checked: @category.weekly?, class: "seg-input" %>
        <span>Week</span>
      </label>
      <label class="seg">
        <%= form.radio_button :period, "monthly", checked: @category.monthly?, class: "seg-input" %>
        <span>Month</span>
      </label>
    </div>
  </fieldset>

  <%= form.submit(@category.new_record? ? "Add category" : "Save changes",
        id: "category-submit", class: "btn btn-primary btn-block native:hidden") %>
<% end %>
