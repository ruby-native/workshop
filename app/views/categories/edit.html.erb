<% content_for :title, "Edit category" %>

<%= native_form_tag %>
<%= native_navbar_tag("Edit category") do |navbar| %>
  <% navbar.submit_button title: "Save", click: "#category-submit" %>
<% end %>

<header class="native:hidden mb-[18px] flex items-center gap-1.5">
  <%= link_to "‹ Settings", settings_path, class: "px-0.5 py-1 text-[15px] font-semibold text-muted" %>
  <h1 class="text-xl font-bold tracking-tight">Edit category</h1>
</header>

<div class="rounded-2xl border border-line bg-surface p-4 shadow-card">
  <%= render "form" %>
</div>

<%= button_to "Delete category", category_path(@category), method: :delete,
      class: "btn btn-danger btn-block",
      data: { turbo_confirm: "Delete #{@category.name}? Its expenses will be removed too." } %>
