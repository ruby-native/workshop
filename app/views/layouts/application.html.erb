<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} · Penny Pincher" : "Penny Pincher" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Penny Pincher">
    <meta name="theme-color" content="#16a34a">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "ruby_native", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <%= native_tabs_tag %>

      <header class="native:hidden sticky top-0 z-20 border-b border-line bg-canvas/90 backdrop-blur-md backdrop-saturate-150">
        <div class="mx-auto flex h-14 w-[min(100%-2rem,560px)] items-center justify-between">
          <%= link_to root_path, class: "inline-flex items-center gap-2.5 font-bold text-ink", aria: { label: "Penny Pincher" } do %>
            <span class="grid h-7 w-7 place-items-center rounded-[9px] bg-brand text-lg font-extrabold text-white">¢</span>
            <span class="text-base">Penny Pincher</span>
          <% end %>
          <nav class="flex gap-1">
            <%= link_to "Home", root_path, class: class_names("rounded-[9px] px-3 py-1.5 text-sm font-semibold", current_page?(root_path) ? "bg-surface-2 text-ink" : "text-muted") %>
            <%= link_to "History", summary_path, class: class_names("rounded-[9px] px-3 py-1.5 text-sm font-semibold", current_page?(summary_path) ? "bg-surface-2 text-ink" : "text-muted") %>
            <%= link_to "Settings", settings_path, class: class_names("rounded-[9px] px-3 py-1.5 text-sm font-semibold", current_page?(settings_path) ? "bg-surface-2 text-ink" : "text-muted") %>
          </nav>
        </div>
      </header>
    <% end %>

    <main class="native-inset mx-auto w-[min(100%-2rem,560px)] pt-[18px] pb-11">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>
