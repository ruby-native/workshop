<% content_for :title, "Settings" %>

<%= native_navbar_tag("Settings") do |navbar| %>
  <% navbar.button icon: "ellipsis.circle" do |menu| %>
    <% menu.item "Add category", href: new_category_path, icon: "plus" %>
    <% menu.item "Edit profile", href: edit_profile_path, icon: "pencil" %>
  <% end %>
<% end %>

<header class="native:hidden mb-[18px]">
  <h1 class="text-[26px] font-bold tracking-tight">Settings</h1>
</header>

<section class="mt-[22px]">
  <div class="flex items-baseline justify-between">
    <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Categories</h2>
    <%= link_to "Add", new_category_path, class: "text-sm font-semibold" %>
  </div>
  <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
    <% @categories.each do |category| %>
      <%= link_to edit_category_path(category), class: "flex w-full items-center gap-3 border-b border-line py-[13px] text-left last:border-b-0" do %>
        <span class="grid h-[38px] w-[38px] shrink-0 place-items-center rounded-[11px] text-[19px]" style="background: color-mix(in srgb, <%= category.color %> 16%, var(--color-surface))"><%= category.emoji %></span>
        <span class="flex min-w-0 flex-1 flex-col">
          <span class="truncate text-[15px] font-semibold"><%= category.name %></span>
          <span class="text-[13px] text-muted"><%= money(category.budget_amount) %> per <%= category.period_label %></span>
        </span>
        <span class="whitespace-nowrap font-bold text-muted">›</span>
      <% end %>
    <% end %>
  </div>
</section>

<section class="mt-[22px]">
  <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Account</h2>
  <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
    <%= link_to edit_profile_path, class: "flex w-full items-center gap-3 py-[13px] text-left" do %>
      <span class="grid h-[38px] w-[38px] shrink-0 place-items-center rounded-full bg-brand-soft text-sm font-bold text-brand-strong"><%= current_user.initials %></span>
      <span class="flex min-w-0 flex-1 flex-col">
        <span class="truncate text-[15px] font-semibold"><%= current_user.display_name %></span>
        <span class="text-[13px] text-muted"><%= current_user.email_address %></span>
      </span>
      <span class="whitespace-nowrap font-bold text-muted">›</span>
    <% end %>
  </div>
  <%= button_to "Sign out", session_path, method: :delete,
        class: "btn btn-ghost btn-block !text-danger", data: { turbo_confirm: "Sign out?" } %>
</section>
