<% content_for :title, "History" %>

<%= native_navbar_tag("History") %>

<header class="screen-head native:hidden">
  <div>
    <p class="eyebrow"><%= current_household.name %></p>
    <h1 class="screen-title">History</h1>
  </div>
</header>

<section class="block">
  <h2 class="block-title">Weeks</h2>
  <div class="card list">
    <%= render partial: "period", collection: @history.weeks, as: :period %>
  </div>
</section>

<section class="block">
  <h2 class="block-title">Months</h2>
  <div class="card list">
    <%= render partial: "period", collection: @history.months, as: :period %>
  </div>
</section>

<p class="footnote">Each period is compared against your current category budgets.</p>
