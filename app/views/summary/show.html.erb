<% content_for :title, "History" %>

<%= native_navbar_tag("History") %>

<header class="native:hidden mb-[18px]">
  <h1 class="text-[26px] font-bold tracking-tight">History</h1>
</header>

<section class="mt-[22px]">
  <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Weeks</h2>
  <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
    <%= render partial: "period", collection: @history.weeks, as: :period %>
  </div>
</section>

<section class="mt-[22px]">
  <h2 class="mb-2.5 text-[15px] font-bold uppercase tracking-[0.04em] text-muted">Months</h2>
  <div class="rounded-2xl border border-line bg-surface px-4 py-1 shadow-card">
    <%= render partial: "period", collection: @history.months, as: :period %>
  </div>
</section>

<p class="mt-[22px] text-center text-[13px] text-muted">Each period is compared against your current category budgets.</p>
