<% content_for :title, "Edit expense" %>

<%= native_form_tag %>
<%= native_navbar_tag("Edit expense") do |navbar| %>
  <% navbar.submit_button title: "Save", click: "#expense-submit" %>
<% end %>

<header class="native:hidden mb-[18px] flex items-center gap-1.5">
  <%= link_to "‹ Back", root_path, class: "px-0.5 py-1 text-[15px] font-semibold text-muted" %>
  <h1 class="text-xl font-bold tracking-tight">Edit expense</h1>
</header>

<div class="rounded-2xl border border-line bg-surface p-4 shadow-card">
  <%= render "form" %>
</div>

<%= button_to "Delete expense", expense_path(@expense), method: :delete,
      class: "btn btn-danger btn-block",
      data: { turbo_confirm: "Delete this expense?", **native_haptic_data(:warning) } %>
