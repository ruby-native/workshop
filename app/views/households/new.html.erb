<% content_for :title, "Create budget" %>

<%= native_form_tag %>
<%= native_navbar_tag("Create budget") do |navbar| %>
  <% navbar.submit_button title: "Create", click: "#budget-submit" %>
<% end %>

<div class="auth">
  <div class="auth-brand native:hidden">
    <span class="brand-mark brand-mark-lg">¢</span>
    <h1>Create a budget</h1>
    <p>Give it a name. You can invite someone later.</p>
  </div>

  <%= form_with model: @household, class: "card form" do |form| %>
    <% if @household.errors.any? %>
      <div class="form-errors"><%= @household.errors.full_messages.to_sentence.capitalize %>.</div>
    <% end %>
    <div class="field">
      <%= form.label :name, "Budget name" %>
      <%= form.text_field :name, placeholder: "Our budget", autofocus: true %>
    </div>
    <%= form.submit "Create budget", id: "budget-submit", class: "btn btn-primary btn-block native:hidden" %>
  <% end %>

  <p class="auth-switch">
    Have an invite code? <%= link_to "Join a budget", new_join_path %>
  </p>
</div>
