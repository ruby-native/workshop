<% content_for :title, "Rename budget" %>

<%= native_form_tag %>
<%= native_navbar_tag("Rename budget") do |navbar| %>
  <% navbar.submit_button title: "Save", click: "#household-submit" %>
<% end %>

<header class="screen-head with-back native:hidden">
  <%= link_to settings_path, class: "back-link" do %>‹ Settings<% end %>
  <h1 class="screen-title">Rename budget</h1>
</header>

<div class="card">
  <%= form_with model: @household, class: "form" do |form| %>
    <% if @household.errors.any? %>
      <div class="form-errors"><%= @household.errors.full_messages.to_sentence.capitalize %>.</div>
    <% end %>
    <div class="field">
      <%= form.label :name, "Budget name" %>
      <%= form.text_field :name, autofocus: true %>
    </div>
    <%= form.submit "Save", id: "household-submit", class: "btn btn-primary btn-block native:hidden" %>
  <% end %>
</div>
