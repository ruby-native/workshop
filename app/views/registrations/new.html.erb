<% content_for :title, "Create account" %>

<%= native_navbar_tag("Create account") %>

<div class="mx-auto w-[min(100%-2rem,400px)] pt-10">
  <div class="mb-[22px] text-center">
    <span class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-brand text-[34px] font-extrabold text-white">¢</span>
    <h1 class="mt-3.5 text-2xl">Create your account</h1>
    <p class="mt-1.5 text-muted">Track spending the moment it happens.</p>
  </div>

  <%= form_with model: @user, url: registration_path, class: "rounded-2xl border border-line bg-surface p-4 shadow-card" do |form| %>
    <% if @user.errors.any? %>
      <div class="form-errors">
        <%= @user.errors.full_messages.to_sentence.capitalize %>.
      </div>
    <% end %>

    <div class="mb-[15px]">
      <%= form.label :name, "Name", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.text_field :name, autofocus: true, autocomplete: "name", placeholder: "First name" %>
    </div>

    <div class="mb-[15px]">
      <%= form.label :email_address, "Email", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.email_field :email_address, required: true, autocomplete: "username", placeholder: "you@example.com" %>
    </div>

    <div class="mb-[15px]">
      <%= form.label :password, "Password", class: "mb-1.5 block text-sm font-semibold" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password",
            placeholder: "At least 6 characters", minlength: 6, maxlength: 72 %>
    </div>

    <%= form.submit "Create account", class: "btn btn-primary btn-block" %>
  <% end %>

  <p class="mt-[18px] text-center text-[15px] text-muted">
    Already have an account? <%= link_to "Sign in", new_session_path, class: "font-semibold text-brand-strong" %>
  </p>
</div>
